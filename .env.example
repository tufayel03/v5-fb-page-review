# REQUIRED — Server will refuse to start without a strong JWT secret.
# Generate one with: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=your_jwt_secret_here

# Server port
PORT=3000

# Admin credentials (only used for initial database seeding — change before first run!)
ADMIN_EMAIL=admin@yourdomain.com
ADMIN_PASSWORD=change_this_to_a_strong_password

# Optional: Fixed cron secret (auto-generated if not set)
# CRON_SECRET=
